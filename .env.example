# ── PostgreSQL Data Warehouse ──
POSTGRES_USER=retail
POSTGRES_PASSWORD=retail123
POSTGRES_DB=retail_dw
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# ── MinIO Data Lake ──
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://localhost:9000

# ── KiotViet API (Bước 13) ──
# Lấy credentials tại: https://www.kiotviet.vn → Cài đặt → API
# Hướng dẫn chi tiết: docs/kiotviet_setup.md
KIOTVIET_BASE_URL=https://public.kiotapi.com
KIOTVIET_TOKEN_URL=https://id.kiotviet.vn/connect/token
KIOTVIET_CLIENT_ID=
KIOTVIET_CLIENT_SECRET=
KIOTVIET_RETAILER=                          # subdomain (vd: shopcuaban.kiotviet.vn → 'shopcuaban')
KIOTVIET_BRANCH_IDS=                        # csv: '1,2,3' (rỗng = tất cả branch)
KIOTVIET_PAGE_SIZE=100                      # max 100 theo docs KiotViet
KIOTVIET_INITIAL_LOOKBACK_DAYS=30           # lần đầu sync lùi N ngày
KIOTVIET_REQUEST_TIMEOUT=30                 # giây

# ── Notifications ──
ZALO_WEBHOOK_URL=

# ── Metabase (cho script provision dashboards) ──
# Sau khi setup wizard ở http://localhost:3000, điền email + password admin
MB_URL=http://localhost:3000
MB_USER=
MB_PASSWORD=
MB_DATABASE=retail_dw

# ── Email (SMTP) ──
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_PASSWORD=<App Password>
#        (bật 2FA → tạo App Password tại https://myaccount.google.com/apppasswords)
# Outlook/M365: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# Để trống SMTP_HOST hoặc SMTP_TO → tắt email notification (không lỗi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=xyz@gmail.com
SMTP_PASSWORD=xyz123
SMTP_FROM=xyz@gmail.com
SMTP_TO=abc@xyz.com
